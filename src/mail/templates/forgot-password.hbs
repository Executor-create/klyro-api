<!DOCTYPE html>
<html>

<head>
  <meta charset="UTF-8">
  <title>Forgot Password</title>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@500&display=swap"
    rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: #f2f1ef;
      color: #1a1a1a;
      padding: 48px 16px;
      min-height: 100vh;
    }

    .container {
      max-width: 520px;
      margin: 0 auto;
    }

    .card {
      background: #ffffff;
      border-radius: 2px;
      padding: 52px 48px 40px;
    }

    .brand {
      font-family: 'DM Mono', monospace;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #1a1a1a;
      margin-bottom: 52px;
    }

    .greeting {
      font-size: 13px;
      font-weight: 400;
      color: #999;
      letter-spacing: 0.5px;
      margin-bottom: 8px;
    }

    h2 {
      font-size: 30px;
      font-weight: 500;
      color: #1a1a1a;
      letter-spacing: -0.5px;
      margin-bottom: 28px;
    }

    .divider {
      width: 32px;
      height: 2px;
      background: #1a1a1a;
      margin-bottom: 28px;
    }

    p {
      font-size: 15px;
      line-height: 1.75;
      color: #666;
      font-weight: 300;
    }

    .otp-section {
      margin: 36px 0;
    }

    .otp-label {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 2.5px;
      text-transform: uppercase;
      color: #bbb;
      margin-bottom: 14px;
    }

    .otp-code {
      font-family: 'DM Mono', monospace;
      font-size: 44px;
      font-weight: 500;
      letter-spacing: 10px;
      color: #1a1a1a;
      display: block;
      padding: 20px 0 18px;
      border-top: 1px solid #e8e8e8;
      border-bottom: 1px solid #e8e8e8;
    }

    .otp-note {
      margin-top: 12px;
      font-size: 12px;
      color: #bbb;
      font-weight: 400;
      letter-spacing: 0.3px;
    }

    .footer {
      margin-top: 52px;
      padding-top: 24px;
      border-top: 1px solid #f0f0f0;
      font-size: 12px;
      color: #ccc;
      font-weight: 300;
      letter-spacing: 0.5px;
    }
  </style>
</head>

<body>
  <div class="container">
    <div class="card">

      <div class="brand">Klyro</div>

      <div class="greeting">Hello,</div>
      <h2>{{username}}</h2>

      <div class="divider"></div>


      <p>We received a request to reset your password. Click the button below to proceed with resetting your password.
      </p>

      <div style="margin: 36px 0; text-align: center;">
        <a href="{{reset_url}}" style="
          display: inline-block;
          background: #1a1a1a;
          color: #fff;
          font-family: 'DM Sans', sans-serif;
          font-size: 16px;
          font-weight: 500;
          text-decoration: none;
          padding: 16px 40px;
          border-radius: 2px;
          letter-spacing: 1px;
          margin-top: 8px;
        ">Reset Password</a>
        <div class="otp-note">This link is valid for a limited time. If you did not request a password reset, you can
          safely ignore this message.</div>
      </div>

      <div class="footer">&copy; Klyro. All rights reserved.</div>

    </div>
  </div>
</body>

</html>